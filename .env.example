# Скопіюйте у .env і заповніть TELEGRAM_TOKEN (отримайте у @BotFather).
TELEGRAM_TOKEN=

# Дефолтна локація для нових чатів (поки не задали /setlocation).
DEFAULT_PLACE=Київ
DEFAULT_LAT=50.4501
DEFAULT_LON=30.5234
DEFAULT_TZ=Europe/Kyiv

# Як часто нагадувати (хвилини) і вікно робочих годин (локальний час).
DEFAULT_INTERVAL_MIN=90
WORK_START_HOUR=9
WORK_END_HOUR=19

# Свята (ISO-код країни для Nager.Date) і мова Wikipedia "цього дня"/геокодера.
COUNTRY_CODE=UA
WIKI_LANG=uk

# debug|info|warn|error
LOG_LEVEL=info
